{
  "name": "botspot/botspot",
  "description": "BotSpot plugin",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=7.4",
    "jaybizzle/crawler-detect": "^1.2",
    "monperrus/crawler-user-agents": "dev-master"
  },
  "require-dev": {
    "brianhenryie/strauss": "^0.19",
    "phpunit/phpunit": "^9.6",
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
  },
  "scripts": {
    "strauss": [
      "vendor/bin/strauss"
    ],
    "post-install-cmd": [
      "@strauss"
    ],
    "post-update-cmd": [
      "@strauss"
    ]
  },
  "extra": {
    "strauss": {
      "target_directory": "vendor/botspot-prefixed/",
      "namespace_prefix": "BotSpot\\Vendor\\",
      "classmap_prefix": "BotSpot_Vendor_",
      "constant_prefix": "BOTSPOT_VENDOR_",
      "packages": [
        "jaybizzle/crawler-detect",
        "monperrus/crawler-user-agents"
      ],
      "delete_vendor_files": false
    }
  },
  "config": {
    "platform": {
      "php": "7.4.33"
    },
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
